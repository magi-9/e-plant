# Database Config
POSTGRES_USER=eplant_user
POSTGRES_PASSWORD=secure_password_here
POSTGRES_DB=eplant_prod
DB_HOST=db
DB_PORT=5432

# Django Backend config
DJANGO_SETTINGS_MODULE=config.settings.prod
SECRET_KEY=this_is_a_highly_secure_secret_key_change_it_immediately
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,http://localhost
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
SECURE_SSL_REDIRECT=False # Let Nginx handle HTTP -> HTTPS redirection
DEBUG=False

# Admin Credentials Defaults (used in Docker entrypoint to create admin automatically on startup)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@yourdomain.com
DJANGO_SUPERUSER_PASSWORD=secure_admin_password_here

# Mailer configuration
# Development: Mailhog catches all mail — view at http://localhost:8025
# EMAIL_HOST=mailhog
# EMAIL_PORT=1025
# Production: use real SMTP credentials below
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
WAREHOUSE_EMAIL=warehouse@yourdomain.com

# Vite frontend (optional if needed during build in Dockerfile)
VITE_API_URL=/api

# Frontend public URL (used in emails, e.g. email verification links)
FRONTEND_URL=https://yourdomain.com
