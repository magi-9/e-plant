# Database Config
POSTGRES_USER=eplant_user
POSTGRES_PASSWORD=secure_password_here
POSTGRES_DB=eplant_prod
DB_HOST=db
DB_PORT=5432

# Django Backend config
DJANGO_SETTINGS_MODULE=config.settings.prod
SECRET_KEY=this_is_a_highly_secure_secret_key_change_it_immediately
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,api.yourdomain.com,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://api.yourdomain.com,http://localhost
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://api.yourdomain.com
SECURE_SSL_REDIRECT=False # Let Traefik handle HTTP -> HTTPS redirection
DEBUG=False
DJANGO_LOG_LEVEL=INFO
GUNICORN_LOG_LEVEL=info
GUNICORN_WORKERS=4
GUNICORN_THREADS=4
IMPORT_PRODUCTS_ON_STARTUP=false

# Admin Credentials Defaults (used in Docker entrypoint to create admin automatically on startup)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@yourdomain.com
DJANGO_SUPERUSER_PASSWORD=secure_admin_password_here

# Default account provisioning (staging/prod)
CREATE_DEFAULT_USERS=true
DJANGO_DEFAULT_USER_EMAIL=user@yourdomain.com
DJANGO_DEFAULT_USER_PASSWORD=secure_user_password_here

# Mailer configuration
# Development: Mailhog catches all mail — view at http://localhost:8025
# EMAIL_HOST=mailhog
# EMAIL_PORT=1025
# Production: use real SMTP credentials below
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
EMAIL_DOMAIN=yourdomain.com # e.g., yourdomain.com
CONTACT_EMAIL_LOCAL_PART=martin
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
WAREHOUSE_EMAIL=warehouse@yourdomain.com

# Frontend build-time API target (for Dokploy/Traefik subdomain routing)
VITE_API_URL=https://api.yourdomain.com/api
VITE_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
VITE_HMR_HOST=yourdomain.com

# Dokploy + Traefik routing
FRONTEND_DOMAIN=yourdomain.com
API_DOMAIN=api.yourdomain.com
TRAEFIK_ENTRYPOINTS=web,websecure
DOKPLOY_WEBHOOK_TOKEN=replace_with_dokploy_token
DOKPLOY_INTERNAL_HOST=192.168.0.15
DOKPLOY_INTERNAL_PORT=3000

# Frontend public URL (used in emails, e.g. email verification links)
FRONTEND_URL=https://yourdomain.com
