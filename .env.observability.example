# Grafana Cloud Loki endpoint and credentials
# Example URL format:
# GRAFANA_LOKI_URL=https://logs-prod-XXX.grafana.net/loki/api/v1/push
GRAFANA_LOKI_URL=

# Usually your Grafana Cloud stack user ID
GRAFANA_LOKI_USER=


# Grafana Cloud API key with logs:write permission
GRAFANA_LOKI_API_KEY=

# Grafana Cloud Metrics endpoint and credentials
# Example URL format:
# GRAFANA_PROM_URL=https://prometheus-prod-XXX.grafana.net/api/prom/push
GRAFANA_PROM_URL=

# Usually your Grafana Cloud metrics user ID
GRAFANA_PROM_USER=

# Grafana Cloud API key with metrics:write permission
GRAFANA_PROM_API_KEY=

# Optional Sentry DSNs used by app services (set these in Dokploy app env)
SENTRY_DSN_BACKEND=
SENTRY_DSN_FRONTEND=
