# Database Config
POSTGRES_USER=eplant_user
POSTGRES_PASSWORD=secure_password_here
POSTGRES_DB=eplant_prod
DB_HOST=db
DB_PORT=5432

# Django Backend config
DJANGO_SETTINGS_MODULE=config.settings.prod
SECRET_KEY=this_is_a_highly_secure_secret_key_change_it_immediately
ALLOWED_HOSTS=yourdomain.com,digitalabutment.yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://digitalabutment.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://digitalabutment.yourdomain.com
SECURE_SSL_REDIRECT=False
DEBUG=False
DJANGO_LOG_LEVEL=INFO
GUNICORN_LOG_LEVEL=info
GUNICORN_WORKERS=4
GUNICORN_THREADS=4
IMPORT_PRODUCTS_ON_STARTUP=false

# Admin Credentials Defaults (used in Docker entrypoint)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@yourdomain.com
DJANGO_SUPERUSER_PASSWORD=secure_admin_password_here

# Default account provisioning
CREATE_DEFAULT_USERS=true
DJANGO_DEFAULT_USER_EMAIL=user@yourdomain.com
DJANGO_DEFAULT_USER_PASSWORD=secure_user_password_here

# Mailer configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
EMAIL_DOMAIN=yourdomain.com
CONTACT_EMAIL_LOCAL_PART=martin
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
WAREHOUSE_EMAIL=warehouse@yourdomain.com

# Frontend build-time routing/host setup
VITE_API_URL=/api
VITE_LANDING_HOST=yourdomain.com
VITE_SHOP_HOST=digitalabutment.yourdomain.com
VITE_ALLOWED_HOSTS=yourdomain.com,digitalabutment.yourdomain.com
VITE_HMR_HOST=yourdomain.com

# Frontend public URL (used in emails)
FRONTEND_URL=https://yourdomain.com

# Optional observability
GRAFANA_LOKI_URL=
GRAFANA_LOKI_USER=
GRAFANA_LOKI_API_KEY=
