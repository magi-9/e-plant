# Database Config
POSTGRES_USER=eplant_user
POSTGRES_PASSWORD=secure_password_here
POSTGRES_DB=eplant_staging
DB_HOST=db
DB_PORT=5432

# Django Backend config
DJANGO_SETTINGS_MODULE=config.settings.prod
SECRET_KEY=this_is_a_highly_secure_secret_key_change_it_immediately
ALLOWED_HOSTS=dent.tomag.xyz,shop.dent.tomag.xyz,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://dent.tomag.xyz,https://shop.dent.tomag.xyz,http://localhost
CSRF_TRUSTED_ORIGINS=https://dent.tomag.xyz,https://shop.dent.tomag.xyz
SECURE_SSL_REDIRECT=False # Let Traefik handle HTTP -> HTTPS redirection
DEBUG=False
DJANGO_LOG_LEVEL=INFO
GUNICORN_LOG_LEVEL=info
GUNICORN_WORKERS=4
GUNICORN_THREADS=4
IMPORT_PRODUCTS_ON_STARTUP=false

# Admin Credentials Defaults (used in Docker entrypoint to create admin automatically on startup)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@dent.tomag.xyz
DJANGO_SUPERUSER_PASSWORD=secure_admin_password_here

# Default account provisioning (staging/prod)
CREATE_DEFAULT_USERS=true
DJANGO_DEFAULT_USER_EMAIL=user@dent.tomag.xyz
DJANGO_DEFAULT_USER_PASSWORD=secure_user_password_here

# Mailer configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
EMAIL_DOMAIN=dent.tomag.xyz
CONTACT_EMAIL_LOCAL_PART=martin
DEFAULT_FROM_EMAIL=noreply@dent.tomag.xyz
WAREHOUSE_EMAIL=warehouse@dent.tomag.xyz

# Frontend build-time routing/host setup
VITE_API_URL=/api
VITE_LANDING_HOST=dent.tomag.xyz
VITE_SHOP_HOST=shop.dent.tomag.xyz
VITE_HOME_PAGE_READY=true
VITE_ALLOWED_HOSTS=localhost,127.0.0.1,dent.tomag.xyz,shop.dent.tomag.xyz
VITE_HMR_HOST=dent.tomag.xyz

# Dokploy + Traefik routing
STAGING_PRIMARY_DOMAIN=dent.tomag.xyz
STAGING_SHOP_DOMAIN=shop.dent.tomag.xyz
TRAEFIK_ENTRYPOINTS=web,websecure
DOKPLOY_WEBHOOK_TOKEN=replace_with_dokploy_token
DOKPLOY_INTERNAL_HOST=192.168.0.15
DOKPLOY_INTERNAL_PORT=3000

# Frontend public URL (used in emails, e.g. email verification links)
FRONTEND_URL=https://dent.tomag.xyz

# Optional observability
GRAFANA_LOKI_URL=
GRAFANA_LOKI_USER=
GRAFANA_LOKI_API_KEY=