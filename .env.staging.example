# --- Base Domain Config ---
DOMAIN_MAIN=mydomain.com
DOMAIN_SUB=shop.mydomain.com
EMAIL_DOMAIN=da.mydomain.com

# Database Config
POSTGRES_USER=eplant_user
POSTGRES_PASSWORD=change_me_db_password
POSTGRES_DB=eplant_prod
DB_HOST=db
DB_PORT=5432

# Django Backend config
DJANGO_SETTINGS_MODULE=config.settings.prod
SECRET_KEY=change_me_django_secret_key
ALLOWED_HOSTS=${DOMAIN_MAIN},${DOMAIN_SUB}
CORS_ALLOWED_ORIGINS=https://${DOMAIN_MAIN},https://${DOMAIN_SUB}
CSRF_TRUSTED_ORIGINS=https://${DOMAIN_MAIN},https://${DOMAIN_SUB}
SECURE_SSL_REDIRECT=False
DEBUG=False
DJANGO_LOG_LEVEL=INFO
GUNICORN_LOG_LEVEL=info
GUNICORN_WORKERS=4
GUNICORN_THREADS=4
IMPORT_PRODUCTS_ON_STARTUP=false

# Admin Credentials Defaults (used in Docker entrypoint)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@${EMAIL_DOMAIN}
DJANGO_SUPERUSER_PASSWORD=change_me_admin_password

# Default account provisioning
CREATE_DEFAULT_USERS=true
DJANGO_DEFAULT_USER_EMAIL=user@${EMAIL_DOMAIN}
DJANGO_DEFAULT_USER_PASSWORD=change_me_default_user_password

# Mailer configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
# EMAIL_DOMAIN already set in Base Domain Config above
CONTACT_EMAIL_LOCAL_PART=martin
DEFAULT_FROM_EMAIL=noreply@${EMAIL_DOMAIN}
WAREHOUSE_EMAIL=warehouse@${EMAIL_DOMAIN}

# Frontend build-time routing/host setup
VITE_API_URL=/api
VITE_LANDING_HOST=${DOMAIN_MAIN}
VITE_SHOP_HOST=${DOMAIN_SUB}
VITE_HOME_PAGE_READY=false
VITE_ALLOWED_HOSTS=${DOMAIN_MAIN},${DOMAIN_SUB}
VITE_HMR_HOST=${DOMAIN_MAIN}

# Frontend public URL (used in emails)
FRONTEND_URL=https://${DOMAIN_MAIN}

# Optional observability
GRAFANA_LOKI_URL=
GRAFANA_LOKI_USER=
GRAFANA_LOKI_API_KEY=